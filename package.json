{
  "name": "oxalate-frontend",
  "version": "0.9.0",
  "type": "module",
  "description": "Oxalate Portal frontend",
  "author": "Paul-Erik Törrönen",
  "homepage": "https://oxalate.io",
  "license": "GPL-2.0",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "prebuild": "node generateBuildInfo.cjs",
    "start": "env-cmd -f .env.local vite",
    "build:test": "yarn prebuild && vite build",
    "build:stage": "yarn prebuild && env-cmd -f .env.stage vite build",
    "build:production": "yarn prebuild && env-cmd -f .env.production vite build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage .",
    "test:debug": "jest --inspect-brk --runInBand --no-cache",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "preview": "vite preview"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/icons" : "^6.2.2",
    "@ckeditor/ckeditor5-react" : "^11.1.2",
    "@wojtekmaj/react-recaptcha-v3": "^0.1.4",
    "antd" : "^6.3.7",
    "antd-style": "^4.1.0",
    "axios" : "^1.16.0",
    "ckeditor5" : "^47.7.1",
    "dayjs": "^1.11.20",
    "dompurify" : "^3.4.2",
    "env-cmd": "^11.0.0",
    "i18next" : "^26.0.10",
    "i18next-http-backend" : "^3.0.6",
    "prop-types": "^15.8.1",
    "qs" : "^6.15.1",
    "react" : "^19.2.6",
    "react-csv": "^2.2.2",
    "react-dom" : "^19.2.6",
    "react-highlight-words": "^0.21.0",
    "react-i18next" : "^17.0.7",
    "react-router-dom" : "^7.15.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/node" : "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-csv": "^1.1.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-highlight-words": "^0.20.1",
    "@vitejs/plugin-react": "^6.0.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint" : "10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks" : "^7.1.1",
    "eslint-plugin-react-prefer-function-component": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-spellcheck": "^0.0.20",
    "globals" : "^17.6.0",
    "husky": "^9.1.7",
    "jest" : "^30.4.2",
    "jest-environment-jsdom" : "^30.4.1",
    "translation-check": "^1.1.1",
    "ts-jest" : "^29.4.9",
    "typescript" : "^6.0.3",
    "typescript-eslint" : "^8.59.2",
    "vite" : "^8.0.11",
    "vite-plugin-svgr" : "^5.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oxalate-Portal/oxalate-frontend.git"
  }
}
